# ─────────────────────────────────────────────────────────────────────────────
# ddoswep — environment configuration
#
# Option A (recommended): auto-generate from current LAN IP:
#   bash scripts/setup-env.sh          # creates .env automatically
#   bash scripts/setup-env.sh --force  # overwrite existing .env
#
# Option B: manual — copy this file and set PUBLIC_HOST:
#   cp .env.example .env
#   # edit PUBLIC_HOST and the two derived vars below
#
# .env is gitignored; .env.example is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# VM's public IP or hostname (no scheme, no trailing slash)
# Leave blank to let Makefile auto-detect via `hostname -I`
PUBLIC_HOST=192.168.88.128

# Protocol — http for LAN/dev, https if you add TLS termination
PUBLIC_PROTO=http

# Ports exposed on the host
WEB_PORT=3000
API_PORT=8000

# Backend limits
MAX_UPLOAD_MB=200
MAX_CAT_CATEGORIES=2000

# ── Derived — update these whenever PUBLIC_HOST / ports change ───────────────
# These are read directly by docker-compose.yml (compose cannot evaluate
# ${A}://${B}:${C} inline), so we write them explicitly here.
#
NEXT_PUBLIC_API_BASE_URL=http://192.168.88.128:8000
ALLOWED_ORIGINS=http://192.168.88.128:3000
